# PikTag Landing — environment variables
#
# Copy to `.env.local` (gitignored) and fill in the values you want enabled.
# Any var left blank causes its SDK to no-op gracefully — the build still works.
# All `VITE_*` vars are inlined into the client bundle at build time.

# ---- Analytics ----------------------------------------------------------------

# PostHog project key (shared with the mobile app so we can stitch web→app
# users via email later). Default falls back to the mobile app's key in code,
# but set it explicitly in production for clarity.
VITE_PUBLIC_POSTHOG_KEY=phc_CagxzXtHwJ6xXYQ2pdDGmmbh5kRiyQ7ikjFjJnSrr7Hr

# Google Analytics 4 measurement ID (e.g. `G-XXXXXXXXXX`). Leave blank to
# disable GA4 entirely.
VITE_GA_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID — numeric. Leave blank to disable the Pixel.
VITE_META_PIXEL_ID=

# ---- Supabase (used by /reset-password) ---------------------------------------

# Supabase project URL — same project the mobile app talks to.
# Default in code falls back to the production URL, but set explicitly to
# avoid accidental cross-environment leaks.
VITE_SUPABASE_URL=https://kbwfdskulxnhjckdvghj.supabase.co

# Supabase anon key (the same value the mobile app ships with — meant to
# be public, gated by RLS server-side). Leave blank in dev if the page
# isn't being exercised.
VITE_SUPABASE_ANON_KEY=
