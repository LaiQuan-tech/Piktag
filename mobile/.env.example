# Piktag mobile env vars — copy to `.env` and fill in real values.
# Never commit the `.env` file.
#
# For EAS production builds, configure these via `eas secret:create` or
# the EAS project dashboard → Secrets.

# Supabase project credentials. The anon key is technically public
# (RLS-protected) but we still load via env for hygiene + easy rotation.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# NOTE: No EXPO_PUBLIC_GEMINI_API_KEY needed in the client bundle.
# AI tag suggestions go through the `suggest-tags` Supabase Edge
# Function which reads GEMINI_API_KEY from its own server-side
# secret store. Set that secret in Supabase Dashboard → Edge
# Functions → Secrets, not here.

# Google Places API key (used by LocationPickerModal + FriendsMapModal).
# MUST be bundle-id restricted in the GCP Console to ag.pikt.app.
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
