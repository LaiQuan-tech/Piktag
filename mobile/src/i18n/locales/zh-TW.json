  "privacyPolicy": {
    "headerTitle": "隱私權政策",
    "lastUpdated": "最後更新：2026 年 3 月 30 日",
    "section1Title": "1. 我們收集哪些資料",
    "section1Intro": "PikTag Inc.（「我們」）在您使用我們的 app 時會收集下列資訊：",
    "section1Bullet1": "• 帳號資料：電子郵件、電話號碼、姓名、使用者名稱、個人照片",
    "section1Bullet2": "• 個人檔案資料：簡介、標籤、社交連結、biolinks",
    "section1Bullet3": "• 通訊錄：經您同意後，我們會存取您裝置的通訊錄以協助您在 PikTag 上找到朋友",
    "section1Bullet4": "• 位置資訊：經您同意後，概略位置將用於「附近」相關功能",
    "section1Bullet5": "• 使用資料：互動紀錄、QR 掃描、標籤活動",
    "section2Title": "2. 我們如何使用您的資料",
    "section2Bullet1": "• 提供與改善 PikTag 服務",
    "section2Bullet2": "• 透過標籤與 QR code 協助您與其他使用者建立連結",
    "section2Bullet3": "• 寄送好友動態與提醒通知",
    "section2Bullet4": "• 使用去識別化資料產生 AI 標籤建議",
    "section2Bullet5": "• 維護社群安全並防止濫用",
    "section3Title": "3. 資料分享",
    "section3Intro": "我們不會販售您的個人資料。我們只會在下列情形分享資料：",
    "section3Bullet1": "• 依您的隱私設定（公開／好友／摯友／僅限自己）與其他 PikTag 使用者分享",
    "section3Bullet2": "• 與服務供應商分享（Supabase 做資料庫、Google 提供 AI 功能）",
    "section3Bullet3": "• 法律要求時",
    "section4Title": "4. 您的隱私控制",
    "section4Bullet1": "• 每個社群連結／聯絡方式都有 4 層可見度：公開、好友、摯友、僅限自己",
    "section4Bullet2": "• 標籤可以設為公開或私密",
    "section4Bullet3": "• 連結上的隱藏標籤只有您能看到",
    "section4Bullet4": "• 您可以隨時封鎖與檢舉使用者",
    "section5Title": "5. 資料保留",
    "section5Body": "帳號啟用期間我們會保留您的資料。您可以隨時在「設定」中停用或刪除帳號。刪除後我們會在 30 天內移除您的資料。",
    "section6Title": "6. 安全性",
    "section6Body": "我們採用業界標準的加密與安全措施。資料儲存於 Supabase（PostgreSQL）並啟用 Row Level Security 政策。",
    "section7Title": "7. 兒童",
    "section7Body": "PikTag 不提供給 13 歲以下使用者使用。我們不會刻意收集兒童資料。",
    "section8Title": "8. 變更",
    "section8Body": "本政策可能會更新。重大變更時我們會透過 app 通知您。",
    "section9Title": "9. 聯絡方式",
    "section9Body": "PikTag Inc.\n電子郵件：privacy@pikt.ag"
  },
  "termsOfService": {
    "headerTitle": "服務條款",
    "lastUpdated": "最後更新：2026 年 3 月 30 日",
    "section1Title": "1. 接受條款",
    "section1Body": "使用 PikTag 即代表您同意本服務條款。若您不同意，請勿使用本 app。",
    "section2Title": "2. 帳號",
    "section2Bullet1": "• 您必須年滿 13 歲才能使用 PikTag",
    "section2Bullet2": "• 您須自行負責維護帳號安全",
    "section2Bullet3": "• 一人一帳號。請勿建立假帳號或重複帳號",
    "section2Bullet4": "• 您可以隨時停用或刪除帳號",
    "section3Title": "3. 使用者內容",
    "section3Bullet1": "• 您擁有自己建立的內容（簡介、標籤、連結、備註）",
    "section3Bullet2": "• 您授權 PikTag 將您公開的內容展示給其他使用者",
    "section3Bullet3": "• 您不得張貼違法、有害或侵害他人權益的內容",
    "section4Title": "4. 可接受的使用",
    "section4Intro": "您同意不會：",
    "section4Bullet1": "• 騷擾、霸凌或威脅其他使用者",
    "section4Bullet2": "• 建立假帳號或冒充他人",
    "section4Bullet3": "• 利用 PikTag 從事垃圾訊息、釣魚或詐騙",
    "section4Bullet4": "• 未經同意抓取或收集使用者資料",
    "section4Bullet5": "• 嘗試反向工程或破解本 app",
    "section5Title": "5. QR code 與標籤",
    "section5Bullet1": "• 您產生的 QR code 會與您的帳號關聯",
    "section5Bullet2": "• 透過 QR code 附加的隱藏標籤為私人資料，僅您本人可見",
